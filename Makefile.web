# Makefile.web — WebAssembly build for Platformer 2D (Emscripten + raylib PLATFORM_WEB)

PROJECT_NAME = platformer-2d

RAYLIB_ROOT = build/external/raylib-master
RAYLIB_SRC = $(RAYLIB_ROOT)/src
SRC_DIR = src
BUILD_DIR = bin/wasm

CC = emcc

CFLAGS = -Os -Wall -std=c99 -D_DEFAULT_SOURCE -Wno-missing-braces -Wunused-result -DPLATFORM_WEB
CFLAGS += -I$(SRC_DIR) -Iinclude -I$(RAYLIB_SRC) -I$(RAYLIB_SRC)/external

LDFLAGS = -L$(RAYLIB_SRC) -lraylib.web
LDFLAGS += -s USE_GLFW=3 -s WASM=1 -s ALLOW_MEMORY_GROWTH=1 -s TOTAL_MEMORY=128MB -s STACK_SIZE=2MB -s ASYNCIFY -s ASSERTIONS=1
LDFLAGS += --shell-file $(SRC_DIR)/shell.html
LDFLAGS += --preload-file resources/

SRCS = $(SRC_DIR)/main.c $(SRC_DIR)/game.c $(SRC_DIR)/level.c $(SRC_DIR)/tile_config.c $(SRC_DIR)/platform_path.c

VERSION := $(shell grep '^VERSION=' project.conf 2>/dev/null | cut -d= -f2)
ifeq ($(VERSION),)
  VERSION := latest
endif

ACTS_GEN = $(SRC_DIR)/acts.gen.h

.PHONY: all clean package assets

assets:
	@$(MAKE) -f Makefile assets

$(ACTS_GEN):
	@$(MAKE) -f Makefile $(ACTS_GEN)

all: $(BUILD_DIR)/index.html

package: all
	@echo "Packaging for Web..."
	@rm -f $(BUILD_DIR)/$(PROJECT_NAME)_wasm.zip
	@cd $(BUILD_DIR) && zip -r $(PROJECT_NAME)_wasm.zip *
	@echo "Package created: $(BUILD_DIR)/$(PROJECT_NAME)_wasm.zip"

$(BUILD_DIR):
	mkdir -p $(BUILD_DIR)

$(RAYLIB_SRC)/libraylib.web.a:
	@echo "Building Raylib for Web..."
	cd $(RAYLIB_SRC) && $(MAKE) PLATFORM=PLATFORM_WEB

$(BUILD_DIR)/index.html: $(SRCS) $(ACTS_GEN) $(RAYLIB_SRC)/libraylib.web.a | $(BUILD_DIR)
	@echo "Building $(PROJECT_NAME) for Web..."
	$(CC) -o $@ $(SRCS) $(CFLAGS) $(LDFLAGS)

clean:
	rm -rf $(BUILD_DIR)
	@if [ -d "$(RAYLIB_SRC)" ]; then $(MAKE) -C "$(RAYLIB_SRC)" clean; fi
